msgstr "TejCart REST APIを有効にします。"

#. translators: %s: link to the API Keys admin page.
#: src/Settings/Settings_Tabs.php:890
#, php-format
msgid "Create and revoke consumer keys on the %s page."
msgstr "%sページでコンシューマーキーを作成および取り消します。"

#: src/Settings/Settings_Tabs.php:896
msgid "Diagnostics"
msgstr "診断"

#: src/Settings/Settings_Tabs.php:898
msgid "Troubleshooting and health checks."
msgstr "トラブルシューティングと健全性チェック。"

#: src/Settings/Settings_Tabs.php:902
msgid "Log Level"
msgstr "ログレベル"

#: src/Settings/Settings_Tabs.php:906
