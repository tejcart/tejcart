#: src/Settings/Settings_Tabs.php:934
#, php-format
msgid "Review environment info on %1$s, inspect recent events on %2$s, run maintenance actions from %3$s, or view background tasks on %4$s."
msgstr "%1$s で環境情報を確認し、%2$s で最近のイベントを調べ、%3$s からメンテナンスアクションを実行し、%4$s でバックグラウンドタスクを表示します。"

#: src/Settings/Settings_Tabs.php:943
msgid "Security"
msgstr "セキュリティ"

#: src/Settings/Settings_Tabs.php:945
msgid "Bot mitigation and abuse protection."
msgstr "ボットの緩和と不正利用の保護。"

