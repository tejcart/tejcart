msgstr "关闭 — 不写入任何日志"

#: src/Settings/Settings_Tabs.php:907
msgid "Emergency"
msgstr "紧急"

#: src/Settings/Settings_Tabs.php:908
msgid "Alert"
msgstr "警报"

#: src/Settings/Settings_Tabs.php:909
msgid "Critical"
msgstr "严重"

#: src/Settings/Settings_Tabs.php:910
msgid "Error (recommended for production)"
msgstr "错误（生产环境推荐）"

#: src/Settings/Settings_Tabs.php:911
msgid "Warning"
msgstr "警告"

#: src/Settings/Settings_Tabs.php:912
msgid "Notice"
msgstr "通知"

#: src/Settings/Settings_Tabs.php:913
msgid "Info"
msgstr "信息"

#: src/Settings/Settings_Tabs.php:914
