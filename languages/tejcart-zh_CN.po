#, php-format
msgid "Configure per-country and per-state tax rates on the %1$s tab, or connect a live calculation service on the %2$s tab."
msgstr "在 %1$s 标签页上配置按国家和按州的税率，或在 %2$s 标签页上连接实时计算服务。"

#: src/Settings/Settings_Tabs.php:875
msgid "Control programmatic access to your store."
msgstr "控制对您商店的程序化访问。"

#: src/Settings/Settings_Tabs.php:879
msgid "Enable REST API"
msgstr "启用 REST API"

#: src/Settings/Settings_Tabs.php:882
