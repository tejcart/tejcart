msgid "Enable tax rates and calculations."
msgstr "启用税率和税费计算。"

#: src/Settings/Settings_Tabs.php:805
msgid "Prices Include Tax"
msgstr "价格含税"

#: src/Settings/Settings_Tabs.php:808
msgid "Product prices are entered inclusive of tax."
msgstr "输入的商品价格已含税。"

#: src/Settings/Settings_Tabs.php:812
msgid "Calculate Tax Based On"
msgstr "税费计算依据"

