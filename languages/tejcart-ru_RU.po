#: src/Settings/Settings_Tabs.php:505
msgid "Pick up to three brand colors to match your WordPress theme. Leave any color empty to keep the TejCart default. Hover, active, and focus-ring shades are derived automatically — you set one color, we generate the full state machine."
msgstr "Выберите до трёх фирменных цветов для соответствия вашей теме WordPress. Оставьте любой цвет пустым, чтобы сохранить значение TejCart по умолчанию. Оттенки наведения, активного состояния и фокус-кольца выводятся автоматически — вы устанавливаете один цвет, мы генерируем полную машину состояний."

#: src/Settings/Settings_Tabs.php:509
msgid "Primary color"
msgstr "Основной цвет"

#: src/Settings/Settings_Tabs.php:513
msgid "Used for primary buttons like \"Add to cart\", selected swatches, and filled badges. Button label color is computed automatically from the background for AA contrast."
msgstr "Используется для основных кнопок, таких как «Добавить в корзину», выбранных образцов и заполненных значков. Цвет метки кнопки рассчитывается автоматически из фона для контраста AA."

#: src/Settings/Settings_Tabs.php:517
msgid "Link & accent color"
msgstr "Цвет ссылок и акцента"

#: src/Settings/Settings_Tabs.php:521
msgid "Used for inline links and accent text. Leave empty to match the Primary color."
msgstr "Используется для встроенных ссылок и акцентного текста. Оставьте пустым, чтобы соответствовать основному цвету."

#: src/Settings/Settings_Tabs.php:525
msgid "Sale / urgency color"
msgstr "Цвет распродажи / срочности"

#: src/Settings/Settings_Tabs.php:529
msgid "Sale price, strikethrough, and urgency badges. Most stores should leave this on the Polaris default red for instant recognition."
msgstr "Цена распродажи, перечёркивание и значки срочности. Большинству магазинов следует оставить это на красном Polaris по умолчанию для мгновенного распознавания."

#: src/Settings/Settings_Tabs.php:533
msgid "Live preview"
msgstr "Предпросмотр в реальном времени"

#: src/Settings/Settings_Tabs.php:545
msgid "Enable Cart Drawer"
msgstr "Включить панель корзины"

#: src/Settings/Settings_Tabs.php:548
msgid "Show a slide-out cart drawer instead of redirecting to the cart page."
msgstr "Показывать выдвижную панель корзины вместо перенаправления на страницу корзины."

#: src/Settings/Settings_Tabs.php:559
msgid "Redirect After Add to Cart"
msgstr "Перенаправлять после добавления в корзину"

#: src/Settings/Settings_Tabs.php:562
msgid "Redirect to the cart page after a product is added."
msgstr "Перенаправлять на страницу корзины после добавления товара."

#: src/Settings/Settings_Tabs.php:566
msgid "Enable Save for Later"
msgstr "Сохранено на потом"

#: src/Settings/Settings_Tabs.php:569
msgid "Show a \"Save for later\" action on cart items so customers can move them to a persistent saved list and restore them later."
msgstr ""

#: src/Settings/Settings_Tabs.php:573
msgid "Enable Wishlist"
msgstr "Список желаний"

#: src/Settings/Settings_Tabs.php:576
msgid "Show a \"Move to wishlist\" action on cart items and enable the [tejcart_wishlist] shortcode. The cart action only appears for logged-in customers."
msgstr ""

#: src/Settings/Settings_Tabs.php:580
msgid "Minimum Order Amount"
msgstr "Минимальная сумма заказа"

#: src/Settings/Settings_Tabs.php:583
msgid "Block checkout when the cart subtotal is below this amount. Set to 0 to disable."
msgstr "Блокировать оформление, если подытог корзины ниже этой суммы. Установите 0, чтобы отключить."

#: src/Settings/Settings_Tabs.php:587
msgid "Maximum Order Amount"
msgstr "Максимальная сумма заказа"

#: src/Settings/Settings_Tabs.php:590
msgid "Block checkout when the cart subtotal exceeds this amount. Set to 0 to disable."
msgstr "Блокировать оформление, если подытог корзины превышает эту сумму. Установите 0, чтобы отключить."

#: src/Settings/Settings_Tabs.php:599
msgid "Checkout Page"
msgstr "Страница оформления"

#: src/Settings/Settings_Tabs.php:606
msgid "Thank You Page"
msgstr "Страница благодарности"

#: src/Settings/Settings_Tabs.php:613
msgid "Guest Checkout"
msgstr "Гостевое оформление"

#: src/Settings/Settings_Tabs.php:616
msgid "Allow customers to check out without creating an account."
msgstr "Разрешить клиентам оформлять заказ без создания аккаунта."

#: src/Settings/Settings_Tabs.php:620
msgid "Allow Account Creation at Checkout"
msgstr "Разрешить создание аккаунта при оформлении"

#: src/Settings/Settings_Tabs.php:623
msgid "Show a \"create an account\" checkbox on the checkout page for guests."
msgstr "Показать чекбокс «создать аккаунт» на странице оформления для гостей."

#: src/Settings/Settings_Tabs.php:627
msgid "Create Account Checked By Default"
msgstr "Создание аккаунта отмечено по умолчанию"

#: src/Settings/Settings_Tabs.php:630
msgid "When account creation is offered at checkout, pre-check the box."
msgstr "Когда создание аккаунта предлагается при оформлении, заранее отметить чекбокс."

#: src/Settings/Settings_Tabs.php:634
msgid "Terms & Conditions Page"
msgstr "Страница условий использования"

#: src/Settings/Settings_Tabs.php:641
msgid "Enable Order Notes"
msgstr "Включить заметки заказа"

#: src/Settings/Settings_Tabs.php:644
msgid "Allow customers to add notes during checkout."
msgstr "Разрешить клиентам добавлять заметки во время оформления."

#: src/Settings/Settings_Tabs.php:648
msgid "Require Phone Number"
msgstr "Обязательно для участников компании"

#: src/Settings/Settings_Tabs.php:651
msgid "Make the checkout phone field mandatory. Left off by default — a required phone field is a documented cause of checkout abandonment. Turn on only if you need it for delivery."
msgstr ""

#: src/Settings/Settings_Tabs.php:655
msgid "Show Menu on Checkout"
msgstr "Показывать меню при оформлении"

#: src/Settings/Settings_Tabs.php:658
msgid "Display the active theme's primary navigation and footer on the checkout page. Turn off for a distraction-free, conversion-optimised checkout that hides site chrome."
msgstr "Отображать основную навигацию и футер активной темы на странице оформления. Отключите для оформления без отвлекающих элементов, оптимизированного для конверсии, которое скрывает интерфейс сайта."

#: src/Settings/Settings_Tabs.php:666
msgid "Pending order timeout (hours)"
msgstr "Тайм-аут ожидающих заказов (часы)"

#: src/Settings/Settings_Tabs.php:671
msgid "Orders that stay in `pending` longer than this are auto-cancelled and their stock is released. Default 24h."
msgstr "Заказы, остающиеся в статусе `pending` дольше этого срока, автоматически отменяются, а их запас высвобождается. По умолчанию 24 ч."

#: src/Settings/Settings_Tabs.php:685
msgid "\"From\" Name"
msgstr "Имя «От»"

#: src/Settings/Settings_Tabs.php:688
msgid "The name that appears in outgoing TejCart emails."
msgstr "Имя, появляющееся в исходящих письмах TejCart."

#: src/Settings/Settings_Tabs.php:695
msgid "\"From\" Email"
msgstr "Email «От»"

#: src/Settings/Settings_Tabs.php:702
msgid "Support email"
msgstr "Email поддержки"

#: src/Settings/Settings_Tabs.php:705
msgid "Shown to customers as the \"Need help?\" address on receipts. Defaults to the admin email; set a dedicated support mailbox for higher-traffic stores."
msgstr "Показывается клиентам как адрес «Нужна помощь?» на чеках. По умолчанию — email администратора; для магазинов с высоким трафиком задайте отдельный почтовый ящик поддержки."

#: src/Settings/Settings_Tabs.php:709
msgid "Header Image URL"
msgstr "URL изображения заголовка"

#: src/Settings/Settings_Tabs.php:712
msgid "URL of the image shown in the email header."
msgstr "URL изображения, отображаемого в заголовке email."

#: src/Settings/Settings_Tabs.php:716
msgid "Footer Text"
msgstr "Текст подписи"

#: src/Settings/Settings_Tabs.php:732
msgid "Brand / Accent Color"
msgstr "Цвет бренда / акцента"

#: src/Settings/Settings_Tabs.php:735
msgid "Paints the email header band, link colours, and totals row. Does not change the page background."
msgstr "Окрашивает полосу заголовка письма, цвета ссылок и строку итогов. Не меняет фон страницы."

#: src/Settings/Settings_Tabs.php:744
msgid "Enable Shipping"
msgstr "Включить доставку"

#: src/Settings/Settings_Tabs.php:747
msgid "Enable shipping calculations."
msgstr "Включить расчёты доставки."

#: src/Settings/Settings_Tabs.php:751
msgid "Shipping Origin Country"
msgstr "Страна источника доставки"

#: src/Settings/Settings_Tabs.php:758
msgid "Default Shipping Method"
msgstr "Способ доставки по умолчанию"

#: src/Settings/Settings_Tabs.php:769
msgid "Default Shipping Cost"
msgstr "Стоимость доставки по умолчанию"

#: src/Settings/Settings_Tabs.php:772
msgid "Cost applied when the default shipping method is Flat Rate and no shipping zone matches the customer address."
msgstr "Стоимость, применяемая, когда способ доставки по умолчанию — Фиксированная ставка и зона доставки не соответствует адресу клиента."

#: src/Settings/Settings_Tabs.php:776
