msgstr "Permitir que clientes finalizem a compra sem criar uma conta."

#: src/Settings/Settings_Tabs.php:620
msgid "Allow Account Creation at Checkout"
msgstr "Permitir criação de conta no checkout"

#: src/Settings/Settings_Tabs.php:623
